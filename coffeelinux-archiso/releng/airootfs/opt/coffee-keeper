gaming_fixes_updater () {
# OS Fixes..
clear
printf "%b" "\nSetting gaming fixes..\n"
sleep 3
clear
#Enable NTSync...
printf "%b" "\nntsync" > /etc/modules-load.d/ntsync.conf
# fix a bug..
systemctl disable dhcpcd
# VM Max Map Count Fix ie: Horizon Zero Dawn..
printf "%b" "vm.max_map_count=262144" > /etc/sysctl.d/99-vm.max_map_count.conf
clear
#DotNet 4.8 ie: Space Engineers..

# ==============================================================================
# COFFEELINUX HOTFIX MODULE: LIVE SYSTEM COMPONENT CLEANUP & DEPLOYMENT
# ==============================================================================

# --- PART 1: SECURE APPARMOR / SPACE ENGINEERS FIX ---
if [ -f /etc/apparmor.d/srt-bwrap ] || [ -f /etc/apparmor.d/local/srt-bwrap ]; then
    echo "Purging legacy security configurations..."
    if systemctl is-active --quiet apparmor 2>/dev/null; then
        apparmor_parser -R /etc/apparmor.d/srt-bwrap >/dev/null 2>&1 || true
    fi
    rm -f /etc/apparmor.d/srt-bwrap
    rm -f /etc/apparmor.d/local/srt-bwrap
fi

mkdir -p /etc/apparmor.d/local && touch /etc/apparmor.d/local/bwrap
if ! grep -q 'COFFEE_REL_SE_FIX=1' /etc/apparmor.d/bwrap 2>/dev/null; then
    {
        printf '# COFFEE_REL_SE_FIX=1\n'
        printf 'abi <abi/4.0>,\n'
        printf 'include <tunables/global>\n\n'
        printf 'profile bwrap /usr/bin/bwrap flags=(unconfined) {\n'
        printf '  userns,\n'
        printf '  include if exists <local/bwrap>\n'
        printf '}\n'
    } > /etc/apparmor.d/bwrap
    chmod 644 /etc/apparmor.d/bwrap
    if systemctl is-active --quiet apparmor 2>/dev/null; then
        apparmor_parser -r /etc/apparmor.d/bwrap >/dev/null 2>&1 || true
    fi
fi

# --- PART 2: PERFORMANCE TUNING MATRIX ---
if ! grep -q "WINE_NTSYNC" /etc/environment 2>/dev/null; then
    printf "\nWINE_NTSYNC=1\n" >> /etc/environment
fi
if ! grep -q "radv_background_compile" /etc/environment 2>/dev/null; then
    printf "radv_background_compile=true\n" >> /etc/environment
fi

mkdir -p /etc/sysctl.d
COFFEE_TOTAL_PAGES=$(awk '/MemTotal/{print $2}' /proc/meminfo)
if [ -n "$COFFEE_TOTAL_PAGES" ]; then
    SHMMAX_CALC=$((COFFEE_TOTAL_PAGES * 1024))
    SHMALL_CALC=$((COFFEE_TOTAL_PAGES / 4))
    {
        printf "net.core.default_qdisc=fq\n"
        printf "net.ipv4.tcp_congestion_control=bbr\n"
        printf "net.ipv4.tcp_fastopen=3\n"
        printf "kernel.sched_rt_runtime_us=-1\n"
        printf "kernel.shmmax=%s\n" "$SHMMAX_CALC"
        printf "kernel.shmall=%s\n" "$SHMALL_CALC"
        printf "vm.vfs_cache_pressure=50\n"
        printf "vm.swappiness=10\n"
        printf "vm.dirty_bytes=268435456\n"
        printf "vm.dirty_background_bytes=134217728\n"
    } > /etc/sysctl.d/60-coffeelinux.conf
    chmod 644 /etc/sysctl.d/60-coffeelinux.conf
fi

mkdir -p /etc/udev/rules.d
printf 'ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none", ATTR{queue/read_ahead_kb}="4096"\n' > /etc/udev/rules.d/60-io.rules

mkdir -p /etc/systemd
{
    printf "[zram0]\n"
    printf "zram-size = ram / 2\n"
    printf "compression-algorithm = zstd\n"
} > /etc/systemd/zram-generator.conf

mkdir -p /etc/security/limits.d
printf "* soft nofile 524288\n* hard nofile 524288\n" > /etc/security/limits.d/60-coffeelinux.conf

mkdir -p /etc/tmpfiles.d
if [ -n "$COFFEE_TOTAL_PAGES" ] && [ "$COFFEE_TOTAL_PAGES" -gt 15728640 ]; then
    printf "w /sys/kernel/mm/transparent_hugepage/enabled - - - - always\n" > /etc/tmpfiles.d/thp.conf
else
    rm -f /etc/tmpfiles.d/thp.conf
fi

sysctl -p /etc/sysctl.d/60-coffeelinux.conf >/dev/null 2>&1 || true
udevadm control --reload-rules && udevadm trigger
systemctl daemon-reload
if [ -f /usr/lib/systemd/system-generators/systemd-zram-generator ]; then
    /usr/lib/systemd/system-generators/systemd-zram-generator
    systemctl start /dev/zram0 2>/dev/null || true
fi
if [ -f /etc/tmpfiles.d/thp.conf ]; then
    systemd-tmpfiles --create /etc/tmpfiles.d/thp.conf >/dev/null 2>&1 || true
fi

# --- PART 3: AUDIO HARDWARE FIX ---
mkdir -p /etc/systemd/system
if ! grep -q 'coffeelinux-audio' /etc/systemd/system/coffeelinux-audio.service 2>/dev/null; then
    {
        printf 'w /sys/module/snd_hda_intel/parameters/power_save - - - - 0\n'
        printf 'w /sys/module/snd_hda_intel/parameters/power_save_node - - - - N\n'
    } > /etc/tmpfiles.d/coffeelinux-audio.conf
    {
        printf '[Unit]\n'
        printf 'Description=CoffeeLinux Global Audio Hardware Gain Initialization\n'
        printf 'After=alsa-restore.service sound.target\n\n'
        printf '[Service]\n'
        printf 'Type=oneshot\n'
        printf 'ExecStart=/bin/sh -c "/usr/bin/amixer sset Master 100%% unmute || true; /usr/bin/amixer sset PCM 100%% unmute || true; /usr/bin/amixer sset Front 100%% unmute || true"\n'
        printf 'RemainAfterExit=yes\n\n'
        printf '[Install]\n'
        printf 'WantedBy=multi-user.target\n'
    } > /etc/systemd/system/coffeelinux-audio.service
    chmod 644 /etc/systemd/system/coffeelinux-audio.service
    systemctl daemon-reload
    systemctl enable --now coffeelinux-audio.service >/dev/null 2>&1 || true
    systemd-tmpfiles --create /etc/tmpfiles.d/coffeelinux-audio.conf >/dev/null 2>&1 || true
    /usr/bin/amixer sset Master 100% unmute >/dev/null 2>&1 || true
    /usr/bin/amixer sset PCM 100% unmute >/dev/null 2>&1 || true
    /usr/bin/amixer sset Front 100% unmute >/dev/null 2>&1 || true
fi

}

