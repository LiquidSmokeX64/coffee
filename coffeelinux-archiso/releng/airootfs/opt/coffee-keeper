#!/bin/sh
#Coffee Auto-Updater tool
sleep 3
#All systems go..
system_updates () {
#Do system updates to all packages
printf "%b" "\nUpdating Arch Linux OS files..\n"
sleep 3
clear
pacman -Syu --noconfirm
#pacman -Syy --noconfirm btop
clear
#Find a user for yay updates
user01=$(logname)
clear
printf "%b" "\nPreparing AUR environment..\n"
sleep 3
#Run yay commands
clear
printf "%b" "\nUpdating current AUR applications..\n"
sleep 3
clear
printf "%b" "1\n" | sudo -Su "$user01" yay -Syu --noconfirm
clear
printf "%b" "\nAdding any new AUR applications..\n"
sleep 3
clear
#printf "%b" "1\n" | sudo -Su "$user01" yay --noconfirm --diffmenu=false --noremovemake --answerclean a --answerdiff n --answeredit y --answerupgrade y shelly
clear
#Remove temporary user
printf "%b" "\nCleaning up afterwards..\n"
sleep 3
clear
#Remove any unwanted files if they exist.
coffeedesktoptype01=$(basename -a /usr/share/wayland-sessions/plas*)
if [ "$coffeedesktoptype01" = "plasma.desktop" ]; then
pacman -Rdd --noconfirm konsole
pacman -Rdd --noconfirm kmix
pacman -Rdd --noconfirm evince
pacman -Rdd --noconfirm totem
pacman -Rdd --noconfirm pamac-aur
fi
coffeedesktoptype00=$(basename -a /usr/share/wayland-sessions/gnome.*)
if [ "$coffeedesktoptype00" = "gnome.desktop" ]; then
pacman -Rdd --noconfirm gedit
pacman -Rdd --noconfirm gnome-terminal
pacman -Rdd --noconfirm gnome-console
pacman -Rdd --noconfirm geary
pacman -Syy --noconfirm pantheon-photos
pacman -Rdd --noconfirm pamac-aur
#Add any missing packages.
pacman -Syy --noconfirm file-roller
fi
coffeedesktoptype02=$(basename -a /usr/share/xsessions/cinnamon2*)
if [ "$coffeedesktoptype02" = "cinnamon2d.desktop" ]; then
pacman -Rdd --noconfirm gnome-session
pacman -Rdd --noconfirm lightdm-settings
pacman -Rdd --noconfirm gnome-console
pacman -Rdd --noconfirm gnome-terminal
pacman -Rdd --noconfirm gedit
pacman -Rdd --noconfirm geary
pacman -Rdd --noconfirm nautilus
pacman -Rdd --noconfirm pamac-aur
#Add any missing packages.
pacman -Syy --noconfirm file-roller
#Add any extra fixes
printf "%b" "\n[Seat:*]\ngreeter-session=lightdm-slick-greeter\n" >> /etc/lightdm/lightdm.conf
systemctl enable lightdm
fi
clear
}

